# ============================================================================
# Serenium portal — environment variables
# ============================================================================
# Copy to .env.local for local dev, or set in Vercel → Settings →
# Environment Variables for production/preview. Never commit .env.local.
# ============================================================================

# ---------- Supabase ----------
# Public, shipped in the frontend bundle. Safe to expose.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# Server-only, used by edge functions. NEVER expose client-side.
# Bypasses RLS, treat like a root password.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ---------- Resend (transactional email) ----------
RESEND_API_KEY=re_...
RESEND_FROM_ADDRESS=Serenium <noreply@sereniumai.com>
# Comma-separated list of addresses to CC on internal team notifications.
RESEND_TEAM_NOTIFICATION_EMAILS=contact@sereniumai.com

# ---------- Anthropic (AI assistant) ----------
ANTHROPIC_API_KEY=sk-ant-...
# Optional, defaults to claude-haiku-4-5. Override to pin a specific model.
# ANTHROPIC_MODEL=claude-haiku-4-5

# ---------- Sentry (error tracking, production only) ----------
# Both variables hold the same DSN. The VITE_ prefix is for the browser
# bundle; the plain one is for edge functions. Not a secret.
VITE_SENTRY_DSN=https://your-key@o0000000.ingest.us.sentry.io/0000000
SENTRY_DSN=https://your-key@o0000000.ingest.us.sentry.io/0000000
